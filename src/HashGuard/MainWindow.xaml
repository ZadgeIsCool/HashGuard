<Window x:Class="HashGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HashGuard - File Integrity Verification"
        Height="720" Width="960"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Icon="Resources/app.ico">

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}" />
        <KeyBinding Gesture="Ctrl+R" Command="{Binding ExportReportCommand}" />
        <KeyBinding Gesture="Ctrl+Shift+C" Command="{Binding ClearCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Files..." Click="BtnSelectFiles_Click" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Export Report..." Click="BtnExportReport_Click" InputGestureText="Ctrl+R"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Baseline">
                <MenuItem Header="_Save Baseline..." Click="BtnSaveBaseline_Click"/>
                <MenuItem Header="_Compare with Baseline..." Click="BtnCompareBaseline_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="MenuToggleTheme" Header="Toggle _Dark/Light Theme" Click="MenuToggleTheme_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About HashGuard" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel Margin="8">

                <!-- File Selection / Drop Zone -->
                <Border x:Name="DropZone"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="2"
                        CornerRadius="8"
                        Padding="24"
                        Margin="0,0,0,16"
                        Background="{DynamicResource DropZoneBackground}"
                        MinHeight="100"
                        AllowDrop="True"
                        Drop="Window_Drop"
                        DragOver="Window_DragOver">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📁 Drag &amp; Drop Files Here"
                                   FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="or click 'Select Files' below"
                                   FontSize="12" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- File List -->
                <ListBox x:Name="FileListBox"
                         MaxHeight="120"
                         Margin="0,0,0,8"
                         Visibility="Collapsed"
                         Background="{DynamicResource ControlBackground}"
                         Foreground="{DynamicResource PrimaryTextBrush}"/>

                <!-- Action Buttons Row -->
                <WrapPanel Margin="0,0,0,16" HorizontalAlignment="Center">
                    <Button x:Name="BtnSelectFiles" Content="📂 Select Files"
                            Click="BtnSelectFiles_Click"
                            Style="{DynamicResource PrimaryButton}"
                            Margin="4" Padding="16,8" FontSize="14"/>
                    <Button x:Name="BtnCalculate" Content="🔒 Calculate Hashes"
                            Click="BtnCalculate_Click"
                            Style="{DynamicResource AccentButton}"
                            Margin="4" Padding="16,8" FontSize="14"
                            IsEnabled="False"/>
                    <Button x:Name="BtnCancel" Content="⛔ Cancel"
                            Click="BtnCancel_Click"
                            Margin="4" Padding="16,8" FontSize="14"
                            IsEnabled="False" Visibility="Collapsed"/>
                    <Button x:Name="BtnClear" Content="🗑 Clear"
                            Click="BtnClear_Click"
                            Margin="4" Padding="16,8" FontSize="14"/>
                </WrapPanel>

                <!-- Hash Type Selection -->
                <GroupBox Header="Hash Algorithms" Margin="0,0,0,16"
                          Foreground="{DynamicResource PrimaryTextBrush}">
                    <WrapPanel Margin="8">
                        <CheckBox x:Name="ChkMD5" Content="MD5" IsChecked="True"
                                  Margin="0,0,20,0" VerticalContentAlignment="Center"
                                  Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <CheckBox x:Name="ChkSHA1" Content="SHA-1" IsChecked="True"
                                  Margin="0,0,20,0" VerticalContentAlignment="Center"
                                  Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <CheckBox x:Name="ChkSHA256" Content="SHA-256" IsChecked="True"
                                  Margin="0,0,20,0" VerticalContentAlignment="Center"
                                  Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <CheckBox x:Name="ChkSHA512" Content="SHA-512" IsChecked="False"
                                  Margin="0,0,20,0" VerticalContentAlignment="Center"
                                  Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </WrapPanel>
                </GroupBox>

                <!-- Progress Bar -->
                <StackPanel x:Name="ProgressPanel" Margin="0,0,0,16" Visibility="Collapsed">
                    <TextBlock x:Name="TxtProgress" Text="Processing..."
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Margin="0,0,0,4"/>
                    <ProgressBar x:Name="ProgressBar" Height="20" Minimum="0" Maximum="100"/>
                </StackPanel>

                <!-- Results Area -->
                <GroupBox Header="Results" Margin="0,0,0,16"
                          Foreground="{DynamicResource PrimaryTextBrush}">
                    <StackPanel Margin="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- MD5 -->
                            <TextBlock Text="MD5:" Grid.Row="0" Grid.Column="0"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Margin="0,4"/>
                            <TextBox x:Name="TxtMD5" Grid.Row="0" Grid.Column="1"
                                     IsReadOnly="True" FontFamily="Consolas"
                                     Background="{DynamicResource ControlBackground}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     Margin="0,4"/>
                            <Button Content="📋" Grid.Row="0" Grid.Column="2"
                                    Click="BtnCopyHash_Click" Tag="MD5"
                                    ToolTip="Copy to clipboard"
                                    Margin="4,4" Padding="6,2"/>

                            <!-- SHA1 -->
                            <TextBlock Text="SHA-1:" Grid.Row="1" Grid.Column="0"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Margin="0,4"/>
                            <TextBox x:Name="TxtSHA1" Grid.Row="1" Grid.Column="1"
                                     IsReadOnly="True" FontFamily="Consolas"
                                     Background="{DynamicResource ControlBackground}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     Margin="0,4"/>
                            <Button Content="📋" Grid.Row="1" Grid.Column="2"
                                    Click="BtnCopyHash_Click" Tag="SHA1"
                                    ToolTip="Copy to clipboard"
                                    Margin="4,4" Padding="6,2"/>

                            <!-- SHA256 -->
                            <TextBlock Text="SHA-256:" Grid.Row="2" Grid.Column="0"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Margin="0,4"/>
                            <TextBox x:Name="TxtSHA256" Grid.Row="2" Grid.Column="1"
                                     IsReadOnly="True" FontFamily="Consolas"
                                     Background="{DynamicResource ControlBackground}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     Margin="0,4"/>
                            <Button Content="📋" Grid.Row="2" Grid.Column="2"
                                    Click="BtnCopyHash_Click" Tag="SHA256"
                                    ToolTip="Copy to clipboard"
                                    Margin="4,4" Padding="6,2"/>

                            <!-- SHA512 -->
                            <TextBlock Text="SHA-512:" Grid.Row="3" Grid.Column="0"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Margin="0,4"/>
                            <TextBox x:Name="TxtSHA512" Grid.Row="3" Grid.Column="1"
                                     IsReadOnly="True" FontFamily="Consolas"
                                     Background="{DynamicResource ControlBackground}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     Margin="0,4"/>
                            <Button Content="📋" Grid.Row="3" Grid.Column="2"
                                    Click="BtnCopyHash_Click" Tag="SHA512"
                                    ToolTip="Copy to clipboard"
                                    Margin="4,4" Padding="6,2"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Hash Comparison -->
                <GroupBox Header="Compare Hash" Margin="0,0,0,16"
                          Foreground="{DynamicResource PrimaryTextBrush}">
                    <StackPanel Margin="8">
                        <TextBlock Text="Paste an expected hash to verify against the calculated result:"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtExpectedHash"
                                     FontFamily="Consolas"
                                     Background="{DynamicResource ControlBackground}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     VerticalContentAlignment="Center"
                                     Padding="8,6"/>
                            <Button Content="🔍 Compare" Grid.Column="1"
                                    Click="BtnCompare_Click"
                                    Margin="8,0,0,0" Padding="16,6"/>
                        </Grid>
                        <Border x:Name="ComparisonResultBorder"
                                CornerRadius="4" Padding="12" Margin="0,8,0,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="TxtComparisonResult"
                                       FontSize="14" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </GroupBox>

                <!-- Export Section -->
                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Button x:Name="BtnExportReport" Content="📄 Export Report"
                            Click="BtnExportReport_Click"
                            Margin="4" Padding="16,8" FontSize="14"
                            IsEnabled="False"/>
                    <Button x:Name="BtnSaveBaseline" Content="💾 Save Baseline"
                            Click="BtnSaveBaseline_Click"
                            Margin="4" Padding="16,8" FontSize="14"
                            IsEnabled="False"/>
                    <Button x:Name="BtnCompareBaseline" Content="📊 Compare Baseline"
                            Click="BtnCompareBaseline_Click"
                            Margin="4" Padding="16,8" FontSize="14"
                            IsEnabled="False"/>
                </WrapPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="Ready"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="HashGuard v1.0.0"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
